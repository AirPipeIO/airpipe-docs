{
  "name": "airpipe-docs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "gen:refresh": "node scripts/refresh-snapshots.mjs",
    "gen:config": "node scripts/gen-config-reference.mjs",
    "gen:marketplace": "node scripts/gen-marketplace.mjs",
    "gen": "npm run gen:config && npm run gen:marketplace",
    "prestart": "npm run gen",
    "prebuild": "npm run gen",
    "start": "docusaurus start --host 0.0.0.0",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "^3.2.0",
    "@docusaurus/plugin-content-blog": "^3.2.0",
    "@docusaurus/preset-classic": "^3.2.0",
    "@easyops-cn/docusaurus-search-local": "^0.40.1",
    "@mdx-js/react": "^3.0.0",
    "@tabler/icons-react": "^3.2.0",
    "@xyflow/react": "^12.11.1",
    "clsx": "^2.0.0",
    "dagre": "^0.8.5",
    "docusaurus-theme-github-codeblock": "^2.0.2",
    "js-yaml": "^5.2.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-markdown": "^10.1.0",
    "react-rotating-text": "^1.4.1",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.25.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.2.0",
    "@docusaurus/types": "^3.2.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
